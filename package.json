{
  "scripts": {
    "test": "vitest run",
    "test:e2e": "cypress run",
    "start": "parcel ./src/index.html",
    "build": "rm -rf build && parcel build ./src/index.html --dist-dir build --public-url ./ --no-source-maps",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "yarn build && yarn zip"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@parcel/transformer-sass": "^2.16.4",
    "@types/node": "^20.0.0",
    "bestzip": "^2.2.0",
    "cypress": "^15.13.1",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "sass": "^1.39.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "parcel": "^2.16.4"
  }
}
